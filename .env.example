# SQLite (dev). For production, swap provider in prisma/schema.prisma to postgresql
# and use a Postgres connection string here.
DATABASE_URL="file:./dev.db"

# Single-user gate. Pick a strong password.
APP_PASSWORD="change-me"

# Used to sign the session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"
